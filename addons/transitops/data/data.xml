<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Seed Vehicles -->
        <record id="vehicle_van_05" model="transitops.vehicle">
            <field name="name">Delivery Van (Van-05)</field>
            <field name="registration_number">MH-12-TR-9905</field>
            <field name="type">van</field>
            <field name="max_load_capacity">500.0</field>
            <field name="odometer">12000.0</field>
            <field name="acquisition_cost">25000.0</field>
            <field name="region">West</field>
            <field name="status">available</field>
        </record>

        <record id="vehicle_truck_01" model="transitops.vehicle">
            <field name="name">Heavy Duty Truck (Truck-01)</field>
            <field name="registration_number">MH-12-TR-1101</field>
            <field name="type">truck</field>
            <field name="max_load_capacity">5000.0</field>
            <field name="odometer">45000.0</field>
            <field name="acquisition_cost">75000.0</field>
            <field name="region">North</field>
            <field name="status">available</field>
        </record>

        <!-- Seed Drivers -->
        <record id="driver_alex" model="transitops.driver">
            <field name="name">Alex Mercer</field>
            <field name="license_number">DL-99051234</field>
            <field name="license_category">class_c</field>
            <field name="license_expiry_date" eval="(datetime.now() + timedelta(days=365)).strftime('%Y-%m-%d')"/>
            <field name="contact_number">+91 98765 43210</field>
            <field name="safety_score">92.0</field>
            <field name="status">available</field>
        </record>

        <record id="driver_bob" model="transitops.driver">
            <field name="name">Bob Vance</field>
            <field name="license_number">DL-11015678</field>
            <field name="license_category">class_a</field>
            <field name="license_expiry_date" eval="(datetime.now() + timedelta(days=120)).strftime('%Y-%m-%d')"/>
            <field name="contact_number">+91 98765 43211</field>
            <field name="safety_score">85.0</field>
            <field name="status">available</field>
        </record>
        
        <record id="driver_expired" model="transitops.driver">
            <field name="name">Charlie Brown (Expired)</field>
            <field name="license_number">DL-expired99</field>
            <field name="license_category">class_d</field>
            <field name="license_expiry_date" eval="(datetime.now() - timedelta(days=10)).strftime('%Y-%m-%d')"/>
            <field name="contact_number">+91 98765 43212</field>
            <field name="safety_score">70.0</field>
            <field name="status">off_duty</field>
        </record>

        <!-- Scheduled Action: Check expiring licenses -->
        <record id="ir_cron_check_driver_license" model="ir.cron">
            <field name="name">TransitOps: Check Driver License Expiry</field>
            <field name="model_id" ref="model_transitops_driver"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_license_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
