<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Sequence for Trip Reference -->
        <record id="seq_transitops_trip" model="ir.sequence">
            <field name="name">TransitOps Trip Reference</field>
            <field name="code">transitops.trip</field>
            <field name="prefix">TRIP/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Trip Tree View -->
        <record id="view_transitops_trip_tree" model="ir.ui.view">
            <field name="name">transitops.trip.tree</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <tree string="Trips" decoration-info="status == 'draft'" decoration-warning="status == 'dispatched'" decoration-success="status == 'completed'" decoration-muted="status == 'cancelled'">
                    <field name="name"/>
                    <field name="source"/>
                    <field name="destination"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <field name="planned_distance"/>
                    <field name="revenue"/>
                    <field name="status" widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- Trip Form View -->
        <record id="view_transitops_trip_form" model="ir.ui.view">
            <field name="name">transitops.trip.form</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <form string="Trip">
                    <header>
                        <button name="action_dispatch" string="Dispatch" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                        <button name="action_complete" string="Complete Trip" type="object" class="oe_highlight" invisible="status != 'dispatched'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="status not in ('draft', 'dispatched')"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,dispatched,completed,cancelled"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Route Details">
                                <field name="source" readonly="status != 'draft'"/>
                                <field name="destination" readonly="status != 'draft'"/>
                                <field name="planned_distance" readonly="status != 'draft'"/>
                            </group>
                            <group string="Dispatch Info">
                                <field name="vehicle_id" domain="[('status', '=', 'available')]" readonly="status != 'draft'"/>
                                <field name="driver_id" domain="[('status', '=', 'available')]" readonly="status != 'draft'"/>
                                <field name="cargo_weight" readonly="status != 'draft'"/>
                                <field name="revenue" readonly="status != 'draft'"/>
                            </group>
                        </group>
                        
                        <group string="Trip Completion" invisible="status not in ('dispatched', 'completed')" readonly="status == 'completed'">
                            <group>
                                <field name="final_odometer" required="status == 'dispatched'" readonly="status == 'completed'"/>
                            </group>
                            <group>
                                <field name="fuel_consumed" required="status == 'dispatched'" readonly="status == 'completed'"/>
                                <field name="fuel_cost" required="status == 'dispatched'" readonly="status == 'completed'"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Trip Kanban View -->
        <record id="view_transitops_trip_kanban" model="ir.ui.view">
            <field name="name">transitops.trip.kanban</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column" quick_create="false" records_draggable="false">
                    <field name="name"/>
                    <field name="source"/>
                    <field name="destination"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <field name="planned_distance"/>
                    <field name="status"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <div>
                                        <strong>Route:</strong> <field name="source"/> to <field name="destination"/>
                                    </div>
                                    <div>
                                        <strong>Vehicle:</strong> <field name="vehicle_id"/>
                                    </div>
                                    <div>
                                        <strong>Driver:</strong> <field name="driver_id"/>
                                    </div>
                                    <div>
                                        <strong>Distance:</strong> <field name="planned_distance"/> km
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Trip Search View -->
        <record id="view_transitops_trip_search" model="ir.ui.view">
            <field name="name">transitops.trip.search</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <search string="Search Trips">
                    <field name="name"/>
                    <field name="source"/>
                    <field name="destination"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                    <filter string="Dispatched" name="dispatched" domain="[('status', '=', 'dispatched')]"/>
                    <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                    <filter string="Cancelled" name="cancelled" domain="[('status', '=', 'cancelled')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="groupby_status" context="{'group_by': 'status'}"/>
                        <filter string="Vehicle" name="groupby_vehicle" context="{'group_by': 'vehicle_id'}"/>
                        <filter string="Driver" name="groupby_driver" context="{'group_by': 'driver_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Trip Action -->
        <record id="action_transitops_trip" model="ir.actions.act_window">
            <field name="name">Trips</field>
            <field name="res_model">transitops.trip</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first trip!
                </p>
            </field>
        </record>

        <!-- Trip Menu Item -->
        <menuitem id="menu_transitops_trip_action"
                  name="Trips"
                  action="action_transitops_trip"
                  parent="menu_transitops_operations"
                  sequence="10"/>
    </data>
</odoo>
