<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vehicle Tree View -->
        <record id="view_transitops_vehicle_tree" model="ir.ui.view">
            <field name="name">transitops.vehicle.tree</field>
            <field name="model">transitops.vehicle</field>
            <field name="arch" type="xml">
                <tree string="Vehicles" decoration-info="status == 'available'" decoration-warning="status == 'on_trip'" decoration-muted="status == 'retired'" decoration-danger="status == 'in_shop'">
                    <field name="name"/>
                    <field name="registration_number"/>
                    <field name="type"/>
                    <field name="max_load_capacity"/>
                    <field name="odometer"/>
                    <field name="region"/>
                    <field name="status" widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- Vehicle Form View -->
        <record id="view_transitops_vehicle_form" model="ir.ui.view">
            <field name="name">transitops.vehicle.form</field>
            <field name="model">transitops.vehicle</field>
            <field name="arch" type="xml">
                <form string="Vehicle">
                    <header>
                        <field name="status" widget="statusbar" statusbar_visible="available,on_trip,in_shop,retired" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="e.g. Volvo FH16"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="registration_number" placeholder="e.g. NY-1234-AB"/>
                                <field name="type"/>
                                <field name="max_load_capacity"/>
                            </group>
                            <group>
                                <field name="odometer"/>
                                <field name="region" placeholder="e.g. Northeast"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Performance KPIs" name="kpis">
                                <group>
                                    <group string="Financials">
                                        <field name="total_operational_cost" readonly="1"/>
                                        <field name="total_revenue" readonly="1"/>
                                        <field name="roi" readonly="1"/>
                                    </group>
                                    <group string="Efficiency">
                                        <field name="fuel_efficiency" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vehicle Search View -->
        <record id="view_transitops_vehicle_search" model="ir.ui.view">
            <field name="name">transitops.vehicle.search</field>
            <field name="model">transitops.vehicle</field>
            <field name="arch" type="xml">
                <search string="Search Vehicles">
                    <field name="name"/>
                    <field name="registration_number"/>
                    <field name="region"/>
                    <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                    <filter string="On Trip" name="on_trip" domain="[('status', '=', 'on_trip')]"/>
                    <filter string="In Shop" name="in_shop" domain="[('status', '=', 'in_shop')]"/>
                    <filter string="Retired" name="retired" domain="[('status', '=', 'retired')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Type" name="groupby_type" context="{'group_by': 'type'}"/>
                        <filter string="Status" name="groupby_status" context="{'group_by': 'status'}"/>
                        <filter string="Region" name="groupby_region" context="{'group_by': 'region'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Vehicle Action -->
        <record id="action_transitops_vehicle" model="ir.actions.act_window">
            <field name="name">Vehicles</field>
            <field name="res_model">transitops.vehicle</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first vehicle!
                </p>
            </field>
        </record>

        <!-- Base Menu Hierarchy -->
        <menuitem id="menu_transitops_root" name="TransitOps" sequence="10"/>

        <!-- Parent Menus -->
        <menuitem id="menu_transitops_dashboard" name="Dashboard" parent="menu_transitops_root" sequence="10"/>
        <menuitem id="menu_transitops_operations" name="Operations" parent="menu_transitops_root" sequence="20"/>
        <menuitem id="menu_transitops_reports" name="Reports" parent="menu_transitops_root" sequence="30"/>
        <menuitem id="menu_transitops_configuration" name="Configuration" parent="menu_transitops_root" sequence="100"/>

        <!-- Operational Sub-Menus -->
        <menuitem id="menu_transitops_fuel_log" name="Fuel Logs" parent="menu_transitops_operations" sequence="20"/>
        <menuitem id="menu_transitops_maintenance" name="Maintenance" parent="menu_transitops_operations" sequence="30"/>
        <menuitem id="menu_transitops_expense" name="Expenses" parent="menu_transitops_operations" sequence="40"/>

        <!-- Configuration Menu Items -->
        <menuitem id="menu_transitops_vehicle_action"
                  name="Vehicles"
                  action="action_transitops_vehicle"
                  parent="menu_transitops_configuration"
                  sequence="10"/>
    </data>
</odoo>
