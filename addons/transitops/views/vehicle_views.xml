<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vehicle Tree View -->
        <record id="view_transitops_vehicle_tree" model="ir.ui.view">
            <field name="name">transitops.vehicle.tree</field>
            <field name="model">transitops.vehicle</field>
            <field name="arch" type="xml">
                <tree string="Vehicles" decoration-success="status == 'available'" decoration-info="status == 'on_trip'" decoration-warning="status == 'in_shop'" decoration-danger="status == 'retired'">
                    <field name="registration_number"/>
                    <field name="name"/>
                    <field name="type"/>
                    <field name="max_load_capacity"/>
                    <field name="odometer"/>
                    <field name="acquisition_cost"/>
                    <field name="region"/>
                    <field name="total_operational_cost"/>
                    <field name="fuel_efficiency"/>
                    <field name="roi"/>
                    <field name="status" widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- Vehicle Form View -->
        <record id="view_transitops_vehicle_form" model="ir.ui.view">
            <field name="name">transitops.vehicle.form</field>
            <field name="model">transitops.vehicle</field>
            <field name="arch" type="xml">
                <form string="Vehicle">
                    <header>
                        <field name="status" widget="statusbar" statusbar_visible="available,on_trip,in_shop,retired" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="registration_number" class="oe_edit_only"/>
                            <h1>
                                <field name="registration_number" placeholder="e.g. MH-12-XX-1234"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Core Specifications">
                                <field name="name"/>
                                <field name="brand"/>
                                <field name="manufacture_year"/>
                                <field name="type"/>
                                <field name="fuel_type"/>
                                <field name="max_load_capacity"/>
                                <field name="region"/>
                            </group>
                            <group string="Financials &amp; Usage">
                                <field name="odometer"/>
                                <field name="acquisition_cost"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Analytics" name="analytics">
                                <group>
                                    <group string="Performance Metrics">
                                        <field name="fuel_efficiency" readonly="1"/>
                                        <field name="total_revenue" readonly="1"/>
                                    </group>
                                    <group string="Costs &amp; Profits">
                                        <field name="total_operational_cost" readonly="1"/>
                                        <field name="roi" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Trips" name="trips">
                                <field name="trip_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="source"/>
                                        <field name="destination"/>
                                        <field name="driver_id"/>
                                        <field name="status" widget="badge"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Maintenance Log" name="maintenance">
                                <field name="maintenance_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="description"/>
                                        <field name="cost"/>
                                        <field name="date"/>
                                        <field name="status" widget="badge"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Fuel &amp; Expenses" name="fuel_expenses">
                                <group>
                                    <group string="Fuel Logs">
                                        <field name="fuel_log_ids" context="{'default_vehicle_id': active_id}">
                                            <tree editable="bottom">
                                                <field name="date"/>
                                                <field name="liters"/>
                                                <field name="cost"/>
                                            </tree>
                                        </field>
                                    </group>
                                    <group string="General Expenses">
                                        <field name="expense_ids" context="{'default_vehicle_id': active_id}">
                                            <tree editable="bottom">
                                                <field name="date"/>
                                                <field name="expense_type"/>
                                                <field name="description"/>
                                                <field name="cost"/>
                                            </tree>
                                        </field>
                                    </group>
                                </group>
                            </page>
                            <page string="Odometer History" name="odometer_history">
                                <field name="odometer_log_ids" readonly="1">
                                    <tree>
                                        <field name="date"/>
                                        <field name="value" string="Odometer Value (km)"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Documents" name="documents">
                                <group>
                                    <group string="Certificates &amp; Policies">
                                        <field name="registration_document" widget="binary"/>
                                        <field name="insurance_document" widget="binary"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vehicle Search View -->
        <record id="view_transitops_vehicle_search" model="ir.ui.view">
            <field name="name">transitops.vehicle.search</field>
            <field name="model">transitops.vehicle</field>
            <field name="arch" type="xml">
                <search string="Search Vehicle">
                    <field name="name" string="Vehicle Model"/>
                    <field name="registration_number"/>
                    <field name="region"/>
                    <separator/>
                    <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                    <filter string="On Trip" name="on_trip" domain="[('status', '=', 'on_trip')]"/>
                    <filter string="In Shop" name="in_shop" domain="[('status', '=', 'in_shop')]"/>
                    <filter string="Retired" name="retired" domain="[('status', '=', 'retired')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                        <filter string="Vehicle Type" name="group_by_type" context="{'group_by': 'type'}"/>
                        <filter string="Region" name="group_by_region" context="{'group_by': 'region'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action to open Vehicle list -->
        <record id="action_transitops_vehicle" model="ir.actions.act_window">
            <field name="name">Vehicles</field>
            <field name="res_model">transitops.vehicle</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_transitops_vehicle_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Register your first vehicle!
                </p>
                <p>
                    Manage registration number, model, odometer, and operational cost stats.
                </p>
            </field>
        </record>

        <!-- Link Menu Item to Action -->
        <menuitem id="menu_transitops_vehicle_action"
                  name="Vehicles"
                  action="action_transitops_vehicle"
                  parent="menu_transitops_vehicle"
                  sequence="10"/>
    </data>
</odoo>
