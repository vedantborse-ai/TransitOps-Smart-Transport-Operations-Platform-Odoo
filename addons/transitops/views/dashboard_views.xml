<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vehicle Dashboard Pivot View -->
        <record id="view_transitops_dashboard_pivot" model="ir.ui.view">
            <field name="name">transitops.vehicle.dashboard.pivot</field>
            <field name="model">transitops.vehicle</field>
            <field name="arch" type="xml">
                <pivot string="Fleet KPIs &amp; Performance" sample="1">
                    <field name="region" type="row"/>
                    <field name="type" type="col"/>
                    <field name="total_operational_cost" type="measure"/>
                    <field name="total_revenue" type="measure"/>
                    <field name="roi" type="measure"/>
                    <field name="fuel_efficiency" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Vehicle Dashboard Graph View (ROI & Costs) -->
        <record id="view_transitops_dashboard_graph" model="ir.ui.view">
            <field name="name">transitops.vehicle.dashboard.graph</field>
            <field name="model">transitops.vehicle</field>
            <field name="arch" type="xml">
                <graph string="Fleet Performance Analytics" type="bar" sample="1">
                    <field name="name"/>
                    <field name="roi" type="measure"/>
                    <field name="total_operational_cost" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- Action to open Dashboard -->
        <record id="action_transitops_dashboard" model="ir.actions.act_window">
            <field name="name">Fleet Dashboard</field>
            <field name="res_model">transitops.vehicle</field>
            <field name="view_mode">pivot,graph,tree</field>
            <field name="view_id" ref="view_transitops_dashboard_pivot"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Welcome to the Fleet Dashboard!
                </p>
                <p>
                    Analyze operational costs, vehicle ROI, fuel efficiency, and revenues in real-time.
                </p>
            </field>
        </record>

        <!-- Link Menu Item to Action -->
        <menuitem id="menu_transitops_dashboard_action"
                  name="Fleet Dashboard"
                  action="action_transitops_dashboard"
                  parent="menu_transitops_dashboard"
                  sequence="10"/>

        <!-- Add Actions for reports as well -->
        <record id="action_transitops_report_roi" model="ir.actions.act_window">
            <field name="name">ROI &amp; Cost Analysis</field>
            <field name="res_model">transitops.vehicle</field>
            <field name="view_mode">graph,pivot</field>
            <field name="view_id" ref="view_transitops_dashboard_graph"/>
            <field name="parent_item_id" ref="menu_transitops_reports"/>
        </record>

        <menuitem id="menu_transitops_report_roi_action"
                  name="ROI &amp; Cost Analysis"
                  action="action_transitops_report_roi"
                  parent="menu_transitops_reports"
                  sequence="10"/>
    </data>
</odoo>
