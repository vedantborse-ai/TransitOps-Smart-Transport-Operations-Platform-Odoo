<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Sequence for Maintenance Reference -->
        <record id="seq_transitops_maintenance" model="ir.sequence">
            <field name="name">TransitOps Maintenance Reference</field>
            <field name="code">transitops.maintenance</field>
            <field name="prefix">MAINT/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Maintenance Tree View -->
        <record id="view_transitops_maintenance_tree" model="ir.ui.view">
            <field name="name">transitops.maintenance.tree</field>
            <field name="model">transitops.maintenance</field>
            <field name="arch" type="xml">
                <tree string="Maintenance Records" decoration-info="status == 'draft'" decoration-warning="status == 'in_progress'" decoration-success="status == 'closed'">
                    <field name="name"/>
                    <field name="vehicle_id"/>
                    <field name="description"/>
                    <field name="cost"/>
                    <field name="date"/>
                    <field name="status" widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- Maintenance Form View -->
        <record id="view_transitops_maintenance_form" model="ir.ui.view">
            <field name="name">transitops.maintenance.form</field>
            <field name="model">transitops.maintenance</field>
            <field name="arch" type="xml">
                <form string="Maintenance Record">
                    <header>
                        <button name="action_start" string="Start Work" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                        <button name="action_close" string="Close Log (Repaired)" type="object" class="oe_highlight" invisible="status != 'in_progress'"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,in_progress,closed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <!-- Filter out retired vehicles -->
                                <field name="vehicle_id" domain="[('status', '!=', 'retired')]" readonly="status == 'closed'"/>
                                <field name="cost" readonly="status == 'closed'"/>
                            </group>
                            <group>
                                <field name="date" readonly="status == 'closed'"/>
                            </group>
                        </group>
                        <group string="Details">
                            <field name="description" placeholder="Describe the issue or repair work done..." readonly="status == 'closed'"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Maintenance Kanban View -->
        <record id="view_transitops_maintenance_kanban" model="ir.ui.view">
            <field name="name">transitops.maintenance.kanban</field>
            <field name="model">transitops.maintenance</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column" records_draggable="false">
                    <field name="name"/>
                    <field name="vehicle_id"/>
                    <field name="description"/>
                    <field name="cost"/>
                    <field name="status"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <div>
                                        <strong>Vehicle:</strong> <field name="vehicle_id"/>
                                    </div>
                                    <div class="text-truncate">
                                        <field name="description"/>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            Cost: $<field name="cost"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Action to open Maintenance list -->
        <record id="action_transitops_maintenance" model="ir.actions.act_window">
            <field name="name">Maintenance Records</field>
            <field name="res_model">transitops.maintenance</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Log new maintenance work!
                </p>
                <p>
                    Logging and starting maintenance automatically marks the vehicle as "In Shop" and makes it unavailable for dispatch.
                </p>
            </field>
        </record>

        <!-- Link Menu Item to Action -->
        <menuitem id="menu_transitops_maintenance_action"
                  name="Maintenance Logs"
                  action="action_transitops_maintenance"
                  parent="menu_transitops_maintenance"
                  sequence="10"/>
    </data>
</odoo>
